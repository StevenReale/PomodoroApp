<Window x:Class="PomodoroApp.CompactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro"
        Width="220"
        Height="72"
        MinHeight="12"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#1E1E1E">
    <Window.Resources>
        <!-- Small icon buttons: □ — ✕ -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#383838"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Start/Pause action button -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ── Compact state ── -->
        <StackPanel x:Name="CompactPanel">
            <!-- Header row: draggable, holds timer text + buttons -->
            <DockPanel Margin="8,6,6,4"
                       MouseLeftButtonDown="Header_MouseLeftButtonDown"
                       Background="Transparent"
                       Cursor="SizeAll"
                       LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="{Binding StartPauseButtonText}"
                            Command="{Binding StartPauseCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0,0,6,0"
                            Cursor="Arrow"/>
                    <Button Content="□"
                            ToolTip="Restore full window"
                            Style="{StaticResource IconButtonStyle}"
                            Click="RestoreButton_Click"
                            Margin="0,0,2,0"/>
                    <Button Content="—"
                            ToolTip="Shrink to progress bar"
                            Style="{StaticResource IconButtonStyle}"
                            Click="MicroButton_Click"
                            Margin="0,0,2,0"/>
                    <Button Content="✕"
                            ToolTip="Exit"
                            Style="{StaticResource IconButtonStyle}"
                            Click="ExitButton_Click"/>
                </StackPanel>
                <TextBlock Text="{Binding TimerText}"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Progress bar -->
            <ProgressBar Value="{Binding ProgressPercent}"
                         Minimum="0"
                         Maximum="100"
                         Height="8"
                         BorderThickness="0"
                         Background="#333333"
                         Foreground="#C0392B"/>
        </StackPanel>

        <!-- ── Micro state: just the progress bar ── -->
        <Border x:Name="MicroBorder"
                Visibility="Collapsed"
                Cursor="Hand"
                MouseLeftButtonDown="MicroBorder_MouseLeftButtonDown"
                ToolTip="{Binding TimerText}">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Expand" Click="MicroExpand_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="ExitButton_Click"/>
                </ContextMenu>
            </Border.ContextMenu>
            <ProgressBar Value="{Binding ProgressPercent}"
                         Minimum="0"
                         Maximum="100"
                         BorderThickness="0"
                         Background="#1E1E1E"
                         Foreground="#C0392B"/>
        </Border>
    </Grid>
</Window>
