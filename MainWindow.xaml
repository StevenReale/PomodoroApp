<Window x:Class="PomodoroApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:PomodoroApp.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
        Title="Pomodoro Timer" 
        Height="450" 
        Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Pomodoro"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <RadioButton x:Name="WorkRadioButton"
                             Content="Work"
                             IsChecked="{Binding IsWorkSessionSelected}"
                             FontSize="16"
                             VerticalContentAlignment="Center"
                             Margin="0,0,20,0"/>
                <RadioButton x:Name="BreadRadioButton"
                             VerticalContentAlignment="Center"
                             IsChecked="{Binding IsBreakSessionSelected}"
                             FontSize="16"
                             Content="Break"/>
            </StackPanel>


            <TextBlock Grid.Row="4"
                       x:Name="TimerText"
                       Text="{Binding TimerText}"
                       FontSize="48"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <ProgressBar Grid.Row="6"
                         x:Name="TimerProgressBar"
                         Height="20"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ProgressPercent}"/>

            <StackPanel Grid.Row="8">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                    <Button Content="{Binding StartPauseButtonText}"
                            x:Name="StartPauseButton"
                            Width="80"
                            Margin="5"
                            Command="{Binding StartPauseCommand}"/>
                    <Button Content="Reset"
                            Width="80"
                            Margin="5"
                            Command="{Binding ResetCommand}"/>
                </StackPanel>

                <GroupBox Header="Settings" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="Work duration (minutes):"/>

                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 x:Name="WorkDurationTextBox"
                                 Text="{Binding WorkDurationMinutes}"
                                 HorizontalContentAlignment="Center"/>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="Break duration (minutes):"/>

                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 x:Name="BreakDurationTextBox"
                                 Text="{Binding BreakDurationMinutes}"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </Grid>
    </Border>
</Window>
